@model KurumsalWeb.Models.ViewModel.AdminDashboardViewModel
@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-lg-12">
        <h3 class="page-header"><i class="fa fa-laptop"></i> Dashboard</h3>
    </div>
</div>

<div class="row">
    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="panel panel-primary">
            <div class="panel-heading">Categories</div>
            <div class="panel-body"><h3>@Model.CategoryCount</h3></div>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="panel panel-success">
            <div class="panel-heading">Blog Posts</div>
            <div class="panel-body"><h3>@Model.BlogCount</h3></div>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="panel panel-info">
            <div class="panel-heading">Services</div>
            <div class="panel-body"><h3>@Model.ServiceCount</h3></div>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="panel panel-warning">
            <div class="panel-heading">Sliders</div>
            <div class="panel-body"><h3>@Model.SliderCount</h3></div>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="panel panel-default">
            <div class="panel-heading">Contacts</div>
            <div class="panel-body"><h3>@Model.ContactCount</h3></div>
        </div>
    </div>
    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="panel panel-danger">
            <div class="panel-heading">Admins</div>
            <div class="panel-body"><h3>@Model.AdminCount</h3></div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="panel panel-default">
            <div class="panel-heading"><strong>Latest Blog Posts</strong></div>
            <div class="panel-body">
                @if (Model.LatestBlogs != null && Model.LatestBlogs.Count > 0)
                {
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Category</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var blog in Model.LatestBlogs)
                            {
                                <tr>
                                    <td>@blog.Title</td>
                                    <td>@(blog.Category != null ? blog.Category.CategoryName : "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p>No blog posts yet.</p>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="panel panel-default">
            <div class="panel-heading"><strong>Latest Services</strong></div>
            <div class="panel-body">
                @if (Model.LatestServices != null && Model.LatestServices.Count > 0)
                {
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th>Title</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var service in Model.LatestServices)
                            {
                                <tr>
                                    <td>@service.Title</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p>No services yet.</p>
                }
            </div>
        </div>
    </div>
</div>
