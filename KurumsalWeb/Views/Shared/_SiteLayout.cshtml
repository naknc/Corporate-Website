@using KurumsalWeb.Models.Model
@using KurumsalWeb.Models.ViewModel
@{
    var pageModel = Model as HomePageViewModel;
    var siteIdentity = ViewBag.SiteIdentity as Identity;
    if (siteIdentity == null && pageModel != null)
    {
        siteIdentity = pageModel.Identity;
    }
    var siteTitle = siteIdentity != null && !string.IsNullOrWhiteSpace(siteIdentity.Title)
        ? siteIdentity.Title
        : "Corporate Website";
    var siteDescription = siteIdentity != null && !string.IsNullOrWhiteSpace(siteIdentity.Description)
        ? siteIdentity.Description
        : "Corporate web presence";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - @siteTitle</title>
    <meta name="description" content="@siteDescription" />
    <meta name="keywords" content="@(siteIdentity != null ? siteIdentity.Keywords : string.Empty)" />
    <link href="~/Content/Site.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <script src="~/Scripts/modernizr-2.8.3.js"></script>
</head>
<body>
    <nav class="navbar navbar-inverse navbar-fixed-top site-navbar">
        <div class="container">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                @Html.ActionLink(siteTitle, "Index", "Home", new { area = "" }, new { @class = "navbar-brand" })
            </div>
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav navbar-right">
                    <li><a href="/Home/About">About</a></li>
                    <li><a href="/Home/Services">Services</a></li>
                    <li><a href="/Home/Blog">Blog</a></li>
                    <li><a href="/Home/Contact">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container body-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <p>&copy; @DateTime.Now.Year @siteTitle</p>
        </div>
    </footer>

    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
</body>
</html>
