@model IEnumerable<KurumsalWeb.Models.Model.Blog>
@using System.Linq
@using System.Text.RegularExpressions
@{
    ViewBag.Title = "Blog";
}

@functions {
    public static string ToPlainText(string html)
    {
        if (string.IsNullOrWhiteSpace(html))
        {
            return string.Empty;
        }

        var noHtml = Regex.Replace(html, "<.*?>", " ");
        return Regex.Replace(noHtml, @"\s+", " ").Trim();
    }

    public static string ToExcerpt(string html, int maxLength)
    {
        var text = ToPlainText(html);
        if (text.Length <= maxLength)
        {
            return text;
        }

        return text.Substring(0, maxLength).Trim() + "...";
    }
}

<section class="hero-section">
    <h1>Blog</h1>
    <p>Latest updates and announcements.</p>
</section>

<section class="content-section">
    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var post in Model)
            {
                <div class="col-sm-6 col-md-4">
                    <article class="content-card">
                        @if (!string.IsNullOrWhiteSpace(post.ImageURL))
                        {
                            <img class="content-card-image" src="@post.ImageURL" alt="@post.Title" />
                        }
                        <h3><a href="/Home/BlogDetail/@post.BlogId">@post.Title</a></h3>
                        @if (post.Category != null)
                        {
                            <p class="muted-text">@post.Category.CategoryName</p>
                        }
                        <p>@ToExcerpt(post.Contents, 220)</p>
                    </article>
                </div>
            }
        }
        else
        {
            <div class="col-xs-12">
                <div class="content-card">
                    <p>No blog posts have been published yet.</p>
                </div>
            </div>
        }
    </div>
</section>
